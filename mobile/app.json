{
  "expo": {
    "name": "SGE CECyT 9",
    "slug": "sge-cecyt9-mobile",
    "version": "0.5.0",
    "orientation": "portrait",
    "icon": "./assets/logonovatec.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splashnovatec.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mx.novatec.sgececyt9",
      "infoPlist": {
        "NSCameraUsageDescription": "La app usa la cámara para escanear códigos QR de acceso al estacionamiento."
      }
    },
    "android": {
      "package": "mx.novatec.sgececyt9",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logonovatec.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "CAMERA"
      ]
    },
    "extra": {
      "apiUrl": "https://novatec.onrender.com/api/v1",
      "socketUrl": "https://novatec.onrender.com",
      "eas": {
        "projectId": "4fa9788c-69be-41c0-885c-33c8c63260ef"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "owner": "novatec"
  }
}
