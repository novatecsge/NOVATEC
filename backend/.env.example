# ===== Backend SGE - Render + Neon =====
NODE_ENV=production
PORT=3000

# Neon recomienda usar la cadena pooled para aplicaciones web.
# Debe incluir sslmode=require.
# Ejemplo:
# DATABASE_URL=postgresql://usuario:password@ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=
DB_SSL=true
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000

# URL pública del frontend en Render Static Site.
FRONTEND_URL=https://tu-frontend.onrender.com
ALLOWED_ORIGINS=https://tu-frontend.onrender.com,http://localhost:5173,http://127.0.0.1:5173

# Genera valores largos y diferentes para producción.
JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_QR_SECRET=change_this_qr_secret_min_32_chars

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_QR_EXPIRES_IN=30d

BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
